# Copy to .env and adjust. .env is gitignored.

# --- PostgreSQL ---
POSTGRES_USER=promptkiddie
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=promptkiddie
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection string used by Drizzle / the pk CLI / packages/core
DATABASE_URL=postgres://promptkiddie:changeme_local_only@localhost:5432/promptkiddie

# --- Workspace ---
# Root directory where per-engagement evidence is stored on disk.
PK_EVIDENCE_ROOT=./engagements

# --- Hosted mode (orchestrator container ports) ---
# PK_SSH_PORT=2222
# PK_TTYD_PORT=7681

# --- Orchestrator inbox polling (used by the background session / future frontend) ---
PK_INBOX_POLL_SECONDS=15

# --- AI providers (for the /chat harness) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Observability (optional, enables tracing to Langfuse) ---
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
