{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "promptkiddie": {
      "type": "local",
      "command": ["node", "packages/mcp-server/dist/index.js"],
      "enabled": true,
      "env": {
        "DATABASE_URL": "postgres://promptkiddie:changeme_local_only@localhost:5432/promptkiddie"
      }
    },
    "promptkiddie-tooling": {
      "type": "local",
      "command": ["node", "packages/tooling-mcp/dist/index.js"],
      "enabled": true
    }
  }
}
