{
  "name": "promptkiddie",
  "version": "0.1.0",
  "private": true,
  "description": "AI-orchestrated ethical-hacking workspace with PostgreSQL engagement logging",
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "pk": "tsx packages/cli/src/index.ts",
    "dev": "pnpm --filter @promptkiddie/web dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@promptkiddie/cli": "workspace:*",
    "commander": "^13.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "pg": "^8.13.0"
  },
  "packageManager": "pnpm@9.15.0"
}
